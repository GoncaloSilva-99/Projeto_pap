                    </div>
                    <p class="post-text text-gray-300 mb-4">
                        Grande vitória da equipa hoje! O esforço nos treinos está finalmente a dar frutos. Continuamos focados para o próximo desafio. ⚽💪 #Futebol #Vitória #Equipa
                    </p>
                    <div class="post-media rounded-lg overflow-hidden mb-4 bg-gray-700 flex items-center justify-center">
                        <img src="http://static.photos/sport/320x240/21" alt="Post" class="w-full h-full object-cover">
                    </div>
                    <div class="post-actions flex items-center justify-between pt-4 border-t border-gray-700">
                        <div class="flex items-center gap-[15px]">
                            <button class="like-btn flex items-center space-x-2 text-gray-400 hover:text-red-500 transition group">
                                <i data-feather="heart" class="w-5 h-5 group-hover:fill-current"></i>
                                <span class="like-count">0 likes</span>
                            </button>
                            <button class="comment-btn flex items-center space-x-2 text-gray-400 hover:text-blue-400 transition">
                                <i data-feather="message-circle" class="w-5 h-5"></i>
                                <span class="comment-count">0 comentários</span>
                            </button>
                        </div>
                        <button class="share-btn flex items-center space-x-2 text-gray-400 hover:text-green-400 transition">
                            <i data-feather="share-2" class="w-5 h-5"></i>
                            <span>Partilhar</span>
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Full Screen Comment Modal -->
    <div id="comment-modal" class="fixed inset-0 z-[100] bg-gray-900 hidden">
        <div class="flex flex-col lg:flex-row w-full h-full">
            <!-- Left: Post Content (Visible on Desktop) -->
            <div class="hidden lg:flex lg:w-2/3 h-full bg-black items-center justify-center p-8 overflow-y-auto relative">
                <div id="modal-post-container" class="max-w h-full w-full bg-gray-800 rounded-xl p-6 shadow-2xl flex flex-col">
                    <!-- Content injected via JS -->
                </div>
            </div>

            <!-- Right: Comments -->
            <div class="w-full lg:w-1/3 h-full bg-gray-800 border-l border-gray-700 flex flex-col">
                <!-- Header -->
                <div class="p-4 border-b border-gray-700 flex justify-between items-center bg-gray-800 z-10">
                    <h3 class="text-xl font-bold text-white">Comentários</h3>
                    <button id="close-modal-btn" class="text-gray-400 hover:text-white p-2 rounded-full hover:bg-gray-700 transition">
                        <div class="flex items-center gap-2">
                            <span class="text-sm font-medium">Voltar</span>
                            <i data-feather="x" class="w-5 h-5"></i>
                        </div>
                    </button>
                </div>
                
                <!-- Comments List -->
                <div class="flex-1 overflow-y-auto p-4 space-y-4" id="modal-comments-list">
                    <!-- Comments injected via JS -->
                </div>
            </div>
        </div>
    </div>

    <!-- Image Modal -->
    <div id="image-modal" class="fixed inset-0 bg-black bg-opacity-80 z-50 hidden items-center justify-center p-4">
        <div id="modal-image-container" class="relative">
            <img id="modal-image" src="" alt="Profile Picture Fullscreen" class="max-w-full max-h-full rounded-lg">
            <button id="close-image-modal">
                <i data-feather="x" class="w-3 h-3"></i>
            </button>
        </div>
    </div>

    <!-- Back to Top Button -->
    <a href="#" id="back-to-top" class="hidden fixed bottom-8 right-5 bg-indigo-600 hover:bg-indigo-700 text-white p-3 rounded-full shadow-lg transition-opacity duration-300 z-50" title="Voltar ao topo e recarregar">
        <i data-feather="arrow-up" class="w-5 h-5"></i>
    </a>

    <script>
        // Inicializa os ícones da biblioteca Feather (substitui as tags <i> pelos ícones SVG)
        feather.replace();


        // Função que controla o botão de Seguir/Deixar de Seguir
        function toggleFollow() {
            // Encontra o botão de seguir na página
            const btn = document.getElementById('followBtn');
            // Encontra o texto dentro do botão
            const text = document.getElementById('followText');
            // Encontra o ícone dentro do botão
            const icon = document.getElementById('followIcon');
            
            // Se o texto atual for "Seguir"
            if (text.innerText === 'Seguir') {
                // Muda o texto para "Deixar de Seguir"
                text.innerText = 'Deixar de Seguir';
                // Remove a cor azul (indigo) do botão
                btn.classList.remove('bg-indigo-600', 'hover:bg-indigo-700');
                // Adiciona a cor cinzenta ao botão
                btn.classList.add('bg-gray-600', 'hover:bg-gray-700');
                // Muda o ícone de user-plus para user-minus
                icon.setAttribute('data-feather', 'user-minus');
                feather.replace();
            } else {
                // Se já estiver a seguir, volta o texto para "Seguir"
                text.innerText = 'Seguir';
                // Remove a cor cinzenta
                btn.classList.remove('bg-gray-600', 'hover:bg-gray-700');
                // Adiciona a cor azul de volta
                btn.classList.add('bg-indigo-600', 'hover:bg-indigo-700');
                // Muda o ícone de user-minus para user-plus
                icon.setAttribute('data-feather', 'user-plus');
                feather.replace();
            }
        }

        // --- Lógica do Modal de Imagem (Visualizar foto de perfil em ecrã inteiro) ---
        
        // Encontra o contentor da foto de perfil pequena
        const profilePicContainer = document.getElementById('profile-pic-container');
        // Encontra o modal (janela flutuante) que vai mostrar a imagem grande
        const imageModal = document.getElementById('image-modal');
        // Encontra o elemento de imagem dentro do modal
        const modalImage = document.getElementById('modal-image');
        // Encontra o botão de fechar o modal
        const closeImageModalBtn = document.getElementById('close-image-modal');

        // Verifica se todos os elementos existem na página antes de adicionar eventos
        if (profilePicContainer && imageModal && modalImage && closeImageModalBtn) {
            // Quando se clica na foto de perfil pequena
            profilePicContainer.addEventListener('click', () => {
                // Encontra a imagem real dentro do contentor
                const profilePicImg = document.getElementById('profile-pic-img');
                // Se a imagem existir
                if (profilePicImg) {
                    // Copia o endereço da imagem pequena para a imagem grande do modal
                    modalImage.src = profilePicImg.src;
                    // Remove a classe que esconde o modal
                    imageModal.classList.remove('hidden');
                    // Adiciona a classe para centrar o conteúdo (flex)
                    imageModal.classList.add('flex');
                    // Impede que a página por trás faça scroll
                    document.body.style.overflow = 'hidden';
                }
            });

            // Função para fechar o modal
            const closeModal = () => {
                // Esconde o modal novamente
                imageModal.classList.add('hidden');
                // Remove a formatação de flex
                imageModal.classList.remove('flex');
                // Permite que a página volte a fazer scroll
                document.body.style.overflow = '';
            };

            // Quando se clica no botão de fechar, executa a função de fechar
            closeImageModalBtn.addEventListener('click', closeModal);
            
            // Quando se clica na área escura à volta da imagem, também fecha
            imageModal.addEventListener('click', (e) => {
                // Verifica se o clique foi exatamente no fundo escuro e não na imagem
                if (e.target === imageModal) closeModal();
            });
        }

        // --- Lógica do Modal de Comentários (Abrir post e ver comentários) ---
        
        // Encontra o modal de comentários
        const modal = document.getElementById('comment-modal');
        // Encontra o botão de fechar este modal
        const closeModalBtn = document.getElementById('close-modal-btn');
        // Encontra a área onde o conteúdo do post vai ser mostrado dentro do modal
        const modalPostContainer = document.getElementById('modal-post-container');
        // Encontra a lista onde os comentários vão aparecer
        const modalCommentsList = document.getElementById('modal-comments-list');

        // Função para abrir o modal de um post específico
        const openPostModal = (postCard) => {
            // Pega o ID do post clicado
            const postId = postCard.dataset.postId;
            // Guarda o ID do post atual no modal
            modal.dataset.currentPostId = postId;
            // Adiciona a classe de estilo de cartão ao contentor do modal
            modalPostContainer.classList.add('post-card');
            // Define o ID no contentor também
            modalPostContainer.dataset.postId = postId;

            // Clona (copia) o cabeçalho do post original (nome, foto, data)
            const header = postCard.querySelector('.flex.items-center.justify-between.mb-4').cloneNode(true);
            // Clona o texto do post
            const text = postCard.querySelector('.post-text').cloneNode(true);
            // Clona a imagem/media do post
            const media = postCard.querySelector('.post-media').cloneNode(true);
            // Clona os botões de ação (like, comentar, partilhar)
            const actions = postCard.querySelector('.post-actions').cloneNode(true);

            // Ajusta o estilo da imagem para caber bem no modal (remove altura fixa)
            media.classList.remove('h-64', 'mb-4');
            media.classList.add('flex-1', 'w-full');

            // Limpa qualquer conteúdo antigo do modal
            modalPostContainer.innerHTML = '';
            // Adiciona as cópias dos elementos ao modal
            modalPostContainer.appendChild(header);
            modalPostContainer.appendChild(text);
            modalPostContainer.appendChild(media);
            modalPostContainer.appendChild(actions);

            // Reinicializa os ícones nos elementos copiados
            feather.replace();

            // Se for o post número 1, adiciona um comentário de exemplo manualmente
            if (postId === "1") {
                modalCommentsList.innerHTML = `
                    <div class="flex items-start space-x-3">
                        <div class="w-8 h-8 rounded-full bg-gray-600 flex-shrink-0 flex items-center justify-center text-xs text-white">U</div>
                        <div class="bg-gray-700 rounded-lg p-3 flex-1">
                            <div class="flex justify-between items-center mb-1">
                                <p class="text-sm font-semibold text-white">Utilizador Exemplo</p>
                                <span class="text-xs text-gray-400">Há 2 horas</span>
                            </div>
                            <p class="text-sm text-gray-300">Grande jogo! Parabéns à equipa. 👏</p>
                        </div>
                    </div>`;
            } else {
                // Para outros posts, mantém a mensagem de vazio
                modalCommentsList.innerHTML = '<p class="text-gray-400 text-sm text-center">Ainda não há comentários.</p>';
            }

            // Mostra o modal removendo a classe 'hidden'
            modal.classList.remove('hidden');
            // Bloqueia o scroll da página principal
            document.body.style.overflow = 'hidden';
        };

        // Se o botão de fechar existir, adiciona o evento de clique
        if (closeModalBtn) {
            closeModalBtn.addEventListener('click', () => {
                // Esconde o modal
                modal.classList.add('hidden');
                // Restaura o scroll da página
                document.body.style.overflow = '';
            });
        }

        // --- Delegação de Eventos para os Posts (Gerir cliques em qualquer post) ---
        // Adiciona um "ouvinte" de cliques na página inteira
        document.body.addEventListener('click', (e) => {
            // Identifica onde foi o clique
            const target = e.target;

            // --- Botão de Opções (três pontinhos) ---
            // Verifica se clicou no botão de opções ou dentro dele
            const optionsBtn = target.closest('.post-options-btn');
            if (optionsBtn) {
                // Impede que o clique se propague para outros elementos
                e.stopPropagation();
                // Fecha todos os outros menus dropdown abertos
                document.querySelectorAll('.post-options-dropdown').forEach(d => {
                    if (d !== optionsBtn.nextElementSibling) d.classList.add('hidden');
                });
                // Alterna (abre/fecha) o menu dropdown deste botão específico
                optionsBtn.nextElementSibling.classList.toggle('hidden');
                return; // Para a execução aqui
            }
            // Se clicou fora de qualquer menu dropdown, fecha todos
            if (!target.closest('.post-options-dropdown')) {
                document.querySelectorAll('.post-options-dropdown').forEach(d => d.classList.add('hidden'));
            }

            // --- Botão de Comentar ---
            // Verifica se clicou no botão de comentar
            const commentBtn = target.closest('.comment-btn');
            if (commentBtn) {
                e.stopPropagation();
                // Encontra o cartão do post a que este botão pertence
                const postCard = commentBtn.closest('.post-card');
                // Abre o modal desse post
                openPostModal(postCard);
                return;
            }

            // --- Clique Geral no Post ---
            // Verifica se clicou em qualquer parte do cartão do post
            const postCard = target.closest('.post-card');
            // Garante que não clicou num link, botão ou campo de texto (para não abrir o modal sem querer)
            if (postCard && !target.closest('a') && !target.closest('button') && !target.closest('input') && !target.closest('textarea')) {
                // Abre o modal do post
                openPostModal(postCard);
            }
        });

        // --- Lógica do Botão "Voltar ao Topo" ---
        // Encontra o botão de voltar ao topo
        const backToTopBtn = document.getElementById('back-to-top');
        // Encontra todos os posts na página
        const posts = document.querySelectorAll('.post-card');

        // Só ativa se o botão existir e houver mais de 1 post
        if (backToTopBtn && posts.length > 1) {
            // Define que o botão aparece depois de passar pelo segundo post
            const secondPost = posts[1];
            const showAt = secondPost.offsetTop;

            // Ouve o evento de scroll da janela
            window.addEventListener('scroll', () => {
                // Se a posição do scroll for maior que a posição do segundo post
                if (window.scrollY > showAt) {
                    // Mostra o botão
                    backToTopBtn.classList.remove('hidden');
                } else {
                    // Esconde o botão
                    backToTopBtn.classList.add('hidden');
                }
            });

            // Quando clica no botão de voltar ao topo
            backToTopBtn.addEventListener('click', (e) => {
                e.preventDefault(); // Previne comportamento padrão do link
                // Rola suavemente até ao topo da página
                window.scrollTo({ top: 0, behavior: 'smooth' });
                // Espera um pouco (200ms) e recarrega a página (simulando atualização)
                setTimeout(() => {
                    location.reload();
                }, 200);
            });
        }
    </script>

    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap');
        
        body {
            font-family: 'Inter', sans-serif;
            transition: all 0.3s ease;
        }
        
        .profile-pic {
            border: 4px solid #1e293b;
            transition: transform 0.3s ease;
        }
        
        .profile-pic:hover {
            transform: scale(1.05);
        }
        
        .post-card {
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }
        
        .post-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1);
        }
        
        .fade-in {
            animation: fadeIn 0.5s ease-in;
        }
        
        @keyframes fadeIn {
            from { opacity: 0; }
            to { opacity: 1; }
        }

        /* Thin Scrollbar for Emoji Picker */
        .thin-scrollbar::-webkit-scrollbar {
            height: 2px;
        }
        .thin-scrollbar::-webkit-scrollbar-track {
            background: transparent;
        }
        .thin-scrollbar::-webkit-scrollbar-thumb {
            background-color: #4b5563;
            border-radius: 20px;
        }

        #modal-image-container #close-image-modal {
            position: absolute;
            top: 1rem;
            right: 1rem;
            background-color: rgba(41, 41, 51, 0.5); /* cinza quase transparente */
            color: white;
            border-radius: 9999px; /* rounded-full */
            padding: 0.5rem; /* p-2 */
            opacity: 0;
            visibility: hidden;
            transition: opacity 0.3s ease, background-color 0.3s ease, visibility 0.3s ease;
        }

        #modal-image-container:hover #close-image-modal {
            opacity: 1;
            visibility: visible;
        }

        #modal-image-container #close-image-modal:hover {
            background-color: #ef4444; /* red-500 */
        }
    </style>

</body> 