<body class="bg-gray-900 text-gray-100 min-h-screen">

    <!-- Banner -->
    <div class="relative h-64 bg-gradient-to-r from-indigo-900 to-purple-900 overflow-hidden">
        <button onclick="window.location.href='/'" class="absolute top-4 left-4 z-20 flex items-center gap-2 px-3 py-2 bg-red-800 bg-opacity-50 hover:bg-opacity-85 rounded-lg transition text-white">
            <i data-feather="arrow-left"></i>
            <span>Voltar</span>
        </button>
        <div class="absolute inset-0 bg-black opacity-30"></div>
        <div class="relative h-full flex items-center justify-center">
            <% if club_profile.banner_picture.attached? %>
                <%= image_tag url_for(club_profile.banner_picture), class: "w-full h-full object-cover" %>
            <% else %>
                <%= image_tag "default_banner.jpg", class: "w-full h-full object-cover" %>
            <% end %>
        </div>
    </div>
    <!-- Profile Picture -->
    <div class="container mx-auto px-4 -mt-12 relative z-10">
        <div class="flex flex-col md:flex-row items-center md:items-end gap-6">
            <div id="profile-pic-container" class="profile-pic w-32 h-32 md:w-40 md:h-40 rounded-full bg-gray-800 overflow-hidden border-4 border-gray-700 shadow-xl cursor-pointer group relative">
                <% if club_profile.profile_picture.attached? %>
                    <%= image_tag url_for(club_profile.profile_picture), class: "w-full h-full object-cover", id: "profile-pic-img" %>
                <% else %>
                    <%= image_tag "default_pp.jpg", class: "w-full h-full object-cover", id: "profile-pic-img" %>
                <% end %>
            </div>
            <!-- Club Name and follow buttons -->
            <div class="flex-1">
                <div class="flex items-center gap-4">
                    <h2 class="text-2xl md:text-3xl font-bold py-1"><%= club_profile.name %></h2>
                    <% if club_profile.status == false && current_user && current_user.id == club_profile.user_id %>
                        <span class="text-sm text-red-500 font-semibold">A aguardar aprovação de um administrador</span>
                    <% end %>
                </div>
                <!-- Botão editar campos -->
                <div class="flex items-center gap-4 mt-4">
                    <% if current_user && current_user.id == club_profile.user_id %>
                        <%= link_to edit_club_profile_path(club_profile), class: "flex items-center gap-2 px-4 py-2 bg-blue-600 hover:bg-blue-700 rounded-lg transition" do %>
                            <i data-feather="edit"></i>
                            <span>Editar Perfil</span>
                        <% end %>
                    <% else %>
                        <button id="followBtn" onclick="toggleFollow()" class="flex items-center gap-2 px-4 py-2 bg-indigo-600 hover:bg-indigo-700 rounded-lg transition">
                            <i data-feather="user-plus" id="followIcon"></i>
                            <span id="followText">Seguir</span>
                        </button>
                        <button class="flex items-center justify-center px-3 py-2 bg-red-600 hover:bg-red-700 rounded-lg transition text-white" title="Denunciar">
                            <i data-feather="flag"></i>
                        </button>
                    <% end %>
                </div>
            </div>
            <!-- Profile Stats -->
            <div class="mt-5 md:mt-0 rounded-xl p-6">
                <div class="flex justify-center text-center gap-8">
                    <div onclick="openFollowersModal()" class="group hover:bg-gray-700 rounded-lg px-4 py-2 transition cursor-pointer">
                        <span class="font-bold text-xl text-gray-100">1.2K</span>
                        <span class="text-gray-400 group-hover:text-indigo-400 transition-colors block text-sm">Seguidores</span>
                    </div>
                    <div class="group hover:bg-gray-700 rounded-lg px-4 py-2 transition cursor-pointer">
                        <span class="font-bold text-xl text-gray-100">56</span>
                        <span class="text-gray-400 group-hover:text-indigo-400 transition-colors block text-sm">A Seguir</span>
                    </div>
                    <div class="rounded-lg px-4 py-2 transition cursor-pointer">
                        <span class="font-bold text-xl text-gray-100">5</span>
                        <span class="text-gray-400 transition-colors block text-sm">Publicações</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Biography Section -->
    <div class="container mx-auto px-4 py-8">
        <!-- Biography -->
            <div class="bg-gray-800 rounded-xl p-6 shadow-lg fade-in mb-8">
                <h3 class="text-xl font-bold mb-4">Biografia</h3>
                <div class="bg-gray-700 rounded-xl py-1 px-8 shadow-lg fade-in whitespace-pre-wrap">
                    <% if club_profile.bio.present? -%>
<%= club_profile.bio %>
                    <%- else -%>
                            <p class="text-gray-300 mb-4">Ainda sem biografia</p>
                    <%- end -%>                    
                </div>
            </div>  
            
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
            <!-- Biography Details -->
            <div class="bg-gray-800 rounded-xl p-6 shadow-lg fade-in space-y-4">
                <h3 class="text-xl font-bold mb-4">Info</h3>
                <div class="space-y-6 mt-1"> 
                    <div class="flex items-center gap-3"> 
                        <i data-feather="calendar" class="text-gray-400"></i>
                        <span class="text-gray-300">Data de Fundação: <%= l(club_profile.foundation_date, format: :long, locale: :pt) %></span>
                    </div> 
                </div> 
                <div class="flex items-start gap-3"> 
                    <i data-feather="award" class="text-gray-400"></i>
                    <div class="text-gray-300">
                        <span>Modalidade(s):</span>
                        <% if club_profile.has_both_sports? %>
                            <span>Futebol | Andebol</span>
                        <% else %>
                            <% if club_profile.has_football? %>
                                <span>Futebol</span>
                            <% elsif club_profile.has_handball? %>
                                <span>Andebol</span>
                            <% end %>
                        <% end %>
                    </div>
                </div> 
            </div>

            <!-- Contact Details -->
            <div class="bg-gray-800 rounded-xl p-6 shadow-lg fade-in">
                <h3 class="text-xl font-bold mb-4">Contactos</h3>
                <div class="space-y-4">
                    <div class="flex items-center gap-3">
                        <i data-feather="phone" class="text-gray-400"></i>
                        <span class="text-gray-300"><%= club_profile.contact || "Contacto não disponível" %></span>
                    </div>
                    <div class="flex items-center gap-3">
                        <i data-feather="mail" class="text-gray-400"></i>
                        <span class="text-gray-300"><%= club_profile.user.email || "Email não disponível" %></span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Main Content -->
    <div class="container mx-auto px-4 py-2">
        <div class="lg:col-span-3 space-y-8">
            
            <!-- Posts Section -->
            <div class="space-y-6">
                <div class="flex items-center justify-between">
                    <h3 class="text-xl font-bold">Publicações</h3>
                    <% if current_user && current_user.id == club_profile.user_id %>
                        <button class="flex items-center gap-2 px-4 py-2 bg-indigo-600 hover:bg-indigo-700 rounded-lg transition">
                            <i data-feather="plus"></i>
                            <span>Publicar</span>
                        </button>
                    <% end %>
                </div>
                
                <!-- Post 1 -->
                <div class="post-card bg-gray-800 rounded-xl p-6 shadow-lg" data-post-id="1">
                    <div class="flex items-center justify-between mb-4">
                        <div class="flex items-center space-x-3">
                            <div class="w-10 h-10 rounded-full bg-gray-700 flex-shrink-0 overflow-hidden flex items-center justify-center">
                                <% if club_profile.profile_picture.attached? %>
                                    <%= image_tag url_for(club_profile.profile_picture), class: "w-full h-full object-cover", id: "profile-pic-img" %>
                                <% else %>
                                    <%= image_tag "default_pp.jpg", class: "w-full h-full object-cover", id: "profile-pic-img" %>
                                <% end %>
                            </div>
                            <div>
                                <h3 class="font-bold text-white"><%= club_profile.name %></h3>
                                <span class="text-gray-400 text-sm">Há 2 horas</span>
                            </div>
                        </div>
                        <div class="relative">
                            <button class="post-options-btn text-gray-400 hover:text-white">
                                <i data-feather="more-vertical"></i>
                            </button>
                            <div class="post-options-dropdown hidden absolute right-0 mt-2 w-56 bg-gray-700 rounded-md shadow-lg z-10 border border-gray-600 overflow-hidden">
                                <a href="#" class="save-post-btn block px-4 py-2 text-sm text-gray-200 hover:bg-gray-600 transition-colors">
                                    <div class="flex items-center"><i data-feather="bookmark" class="w-4 h-4 mr-2"></i><span class="save-text">Guardar publicação</span></div>
                                </a>
                                <a href="#" class="download-img-btn block px-4 py-2 text-sm text-gray-200 hover:bg-gray-600 transition-colors">
                                    <div class="flex items-center"><i data-feather="download" class="w-4 h-4 mr-2"></i><span>Descarregar imagem</span></div>
                                </a>
                                <% if current_user && current_user.id == club_profile.user_id %>
                                    <a href="#" class="delete-post-btn block px-4 py-2 text-sm text-red-400 hover:bg-gray-600 transition-colors">
                                        <div class="flex items-center"><i data-feather="trash-2" class="w-4 h-4 mr-2"></i><span>Remover publicação</span></div>
                                    </a>
                                <% end %>
                            </div>
                        </div>
                    </div>
                    <p class="post-text text-gray-300 mb-4">
                        Grande vitória da equipa hoje! O esforço nos treinos está finalmente a dar frutos. Continuamos focados para o próximo desafio. ⚽💪 #Futebol #Vitória #Equipa
                    </p>
                    <div class="post-media rounded-lg overflow-hidden mb-4 bg-gray-700 flex items-center justify-center">
