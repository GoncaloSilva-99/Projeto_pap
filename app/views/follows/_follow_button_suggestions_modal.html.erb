<%= turbo_frame_tag "follow_button_suggestion_modal_#{user.id}", style: "display: contents;" do %>
    <% if current_user.following?(user) %>
        <%= button_to follow_path(user_id: user.id),
            method: :delete,
            form: { class: "inline" },
            class: "bg-gray-600 hover:bg-gray-500 text-white px-4 py-2 rounded-lg font-medium text-sm transition whitespace-nowrap w-auto flex-shrink-0",
            data: { turbo_frame: "follow_button_suggestion_modal_#{user.id}" } do %>
            A Seguir
        <% end %>
    <% else %>
        <%= button_to follows_path(user_id: user.id),
            method: :post,
            form: { class: "inline" },
            class: "bg-indigo-600 hover:bg-indigo-700 text-white px-4 py-2 rounded-lg font-medium text-sm transition whitespace-nowrap w-20 flex-shrink-0",
            data: { turbo_frame: "follow_button_suggestion_modal_#{user.id}" } do %>
            Seguir
        <% end %>
    <% end %>

    <script>
        feather.replace();
    </script>
<% end %>