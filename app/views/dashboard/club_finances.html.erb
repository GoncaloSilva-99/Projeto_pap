                    <h2 class="text-2xl font-bold text-blue-400">Alterar Saldo da Conta</h2>
                    <button id="close-add-money-modal" class="text-slate-400 hover:text-white">
                        <i data-feather="x"></i>
                    </button>
                </div>
                <form id="add-money-form">
                    <div class="mb-6">
                        <label for="add-money-amount" class="block text-sm font-medium text-slate-300 mb-2">Quantia</label>
                        <input type="number" step="0.01" id="add-money-amount" name="amount" class="w-full bg-slate-900 border border-slate-700 rounded-lg p-2 text-white focus:outline-none focus:ring-2 focus:ring-blue-500" placeholder="0,00 €" required>
                    </div>
                    <button type="submit" class="w-full bg-blue-600 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded-lg transition-colors">
                        Alterar
                    </button>
                </form>
            </div>
        </div>
    </div>
    
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            feather.replace();

            // --- MODAL LOGIC ---
            const openModal = (modal) => {
                console.log('openModal called with:', modal); // Log the modal element received
                if (!modal) {
                    console.error('Error: Modal element is null or undefined. Cannot open modal.');
                    return;
                }
                modal.classList.remove('hidden');
                modal.classList.add('flex');
                console.log('Modal classes after opening:', modal.classList); // Log classes after modification
                feather.replace(); // Re-render icons for the modal (if any new icons are in the modal)
            };

            const closeModal = (modal) => {
                if (!modal) return;
                modal.classList.add('hidden');
                modal.classList.remove('flex');
            };

            const revenueModal = document.getElementById('revenue-modal');
            const addRevenueBtn = document.getElementById('add-revenue-button');
            const closeRevenueBtn = document.getElementById('close-revenue-modal');
            addRevenueBtn?.addEventListener('click', () => openModal(revenueModal));
            closeRevenueBtn?.addEventListener('click', () => closeModal(revenueModal));

            const expenseModal = document.getElementById('expense-modal');
            const addExpenseBtn = document.getElementById('add-expense-button');
            const closeExpenseBtn = document.getElementById('close-expense-modal');
            addExpenseBtn?.addEventListener('click', () => openModal(expenseModal));
            closeExpenseBtn?.addEventListener('click', () => closeModal(expenseModal));

                const addMoneyModal = document.getElementById('add-money-modal');
            const addMoneyTriggers = document.querySelectorAll('.add-money-trigger');
            const closeAddMoneyBtn = document.getElementById('close-add-money-modal');
            const addMoneyForm = document.getElementById('add-money-form');

            addMoneyTriggers.forEach(button => {
                button.addEventListener('click', () => openModal(addMoneyModal));
            });

            closeAddMoneyBtn?.addEventListener('click', () => closeModal(addMoneyModal));

            addMoneyForm?.addEventListener('submit', (event) => {
                event.preventDefault();
                const amountInput = document.getElementById('add-money-amount');
                const amount = parseFloat(amountInput.value);

                if (isNaN(amount) || amount <= 0) {
                    alert('Por favor, insira uma quantia válida.');
                    return;
                }

                if (confirm(`Tem a certeza que quer alterar o saldo da conta para ${amount.toFixed(2)} €?`)) {
                    // Atualizar UI
                    const balanceView = document.getElementById('wallet-balance-view');
                    const emptyView = document.getElementById('wallet-empty-view');
                    const balanceText = document.getElementById('wallet-balance-amount');

                    // Substitui o saldo atual pelo novo valor inserido
                    const newBalance = amount;
                    
                    balanceText.innerText = newBalance.toLocaleString('pt-PT', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) + ' €';
                    
                    emptyView.classList.add('hidden');
                    balanceView.classList.remove('hidden');

                    closeModal(addMoneyModal);
                    amountInput.value = ''; // Limpa o campo do formulário para a próxima utilização
                }
            });

            // --- SEARCH LOGIC ---
            const searchIcon = document.getElementById('search-icon');
            const searchInput = document.getElementById('search-input');

            searchIcon?.addEventListener('click', performSearch);

            searchInput?.addEventListener('keydown', (event) => {
                if (event.key === 'Enter') {
                    performSearch();
                }
            });

            window.addEventListener('click', (event) => {
                if (event.target === revenueModal) closeModal(revenueModal);
                if (event.target === expenseModal) closeModal(expenseModal);
                if (event.target === addMoneyModal) closeModal(addMoneyModal);
            });

            window.addEventListener('keydown', (event) => {
                if (event.key === 'Escape') {
                    if (revenueModal && !revenueModal.classList.contains('hidden')) closeModal(revenueModal);
                    if (expenseModal && !expenseModal.classList.contains('hidden')) closeModal(expenseModal);
                    if (addMoneyModal && !addMoneyModal.classList.contains('hidden')) closeModal(addMoneyModal);
                }
            });

            // --- LOAD MORE LOGIC ---
            const setupLoadMore = (listId, containerId, buttonId, endMessageId, itemsPerLoad) => {
                const list = document.getElementById(listId);
                const container = document.getElementById(containerId);
                const button = document.getElementById(buttonId);
                const endMessage = document.getElementById(endMessageId);
                if (!list || !container || !button || !endMessage) return;

                const items = Array.from(list.children);
                let visibleCount = itemsPerLoad;

                // Hide items that should not be visible initially
                items.forEach((item, index) => {
                    if (index >= visibleCount) {
                        item.classList.add('hidden');
                    }
                });

                const checkScroll = () => {
                    // Check if scrolled to bottom (with small tolerance)
                    const isAtBottom = container.scrollHeight - container.scrollTop - container.clientHeight <= 3;

                    if (visibleCount >= items.length) {
                        button.classList.add('hidden');
                        if (isAtBottom) {
                            endMessage.classList.remove('hidden');
                        } else {
                            endMessage.classList.add('hidden');
                        }
                        return;
                    }

                    endMessage.classList.add('hidden');
                    if (isAtBottom) {
                        button.classList.remove('hidden');
                    } else {
                        button.classList.add('hidden');
                    }
                };

                container.addEventListener('scroll', checkScroll);
                // Initial check
                checkScroll();

                button.addEventListener('click', () => {
                    const nextVisibleCount = visibleCount + itemsPerLoad;
                    for (let i = visibleCount; i < nextVisibleCount && i < items.length; i++) {
                        items[i].classList.remove('hidden');
                    }
                    visibleCount = nextVisibleCount;

                    checkScroll();
                });
            };

            setupLoadMore('revenue-list', 'revenue-scroll-container', 'load-more-revenues', 'end-revenues-msg', 3);
            setupLoadMore('expense-list', 'expense-scroll-container', 'load-more-expenses', 'end-expenses-msg', 3);
        });
    </script>

</body>

<style>
    .sidebar-icon {
        transition: all 0.3s ease;
    }
    
    .sidebar-item:hover .sidebar-icon {
        transform: translateX(5px);
    }

    /* Hide scrollbar for Chrome, Safari and Opera */
    .no-scrollbar::-webkit-scrollbar {
        display: none;
    }

    /* Hide scrollbar for IE, Edge and Firefox */
    .no-scrollbar {
        -ms-overflow-style: none;  /* IE and Edge */
        scrollbar-width: none;  /* Firefox */
    }

    /* Remover setas dos inputs number */
    input[type=number]::-webkit-inner-spin-button, 
    input[type=number]::-webkit-outer-spin-button { 
        -webkit-appearance: none; 
        margin: 0; 
    }
    input[type=number] {
        -moz-appearance: textfield;
    }
</style>