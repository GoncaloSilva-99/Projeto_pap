                            <div>
                                <p class="font-medium text-white">Transporte Equipa Visitante</p>
                                <p class="text-sm text-slate-400">08 de Março, 2026</p>
                            </div>
                            <span class="font-bold text-red-400">- 200,00 €</span>
                        </div>
