                                <p class="text-sm text-slate-400">01 de Março, 2026</p>
                            </div>
                            <span class="font-bold text-red-400">- 100,00 €</span>
                        </div>
                    </div>
                </div>
                <div class="mt-4 text-center">
                    <button id="load-more-expenses" class="text-blue-400 hover:text-blue-300 text-sm font-medium hidden">Carregar mais</button>
                    <p id="end-expenses-msg" class="text-slate-500 text-sm hidden">------------------------- FIM     -------------------------</p>
                </div>
            </div>
        </div>

        <!-- Modal Add Receitas -->
        <div id="revenue-modal" class="fixed inset-0 bg-black bg-opacity-50 hidden items-center justify-center z-50">
            <div class="bg-slate-800 rounded-lg shadow-xl p-8 w-full max-w-md border border-slate-700">
                <div class="flex justify-between items-center mb-6">
                    <h2 class="text-2xl font-bold text-green-400">Adicionar Receita</h2>
                    <button id="close-revenue-modal" class="text-slate-400 hover:text-white">
                        <i data-feather="x"></i>
                    </button>
                </div>
                <form>
                    <div class="mb-4">
                        <label for="revenue-amount" class="block text-sm font-medium text-slate-300 mb-2">Valor</label>
                        <input type="number" step="0.01" id="revenue-amount" name="amount" class="w-full bg-slate-900 border border-slate-700 rounded-lg p-2 text-white focus:outline-none focus:ring-2 focus:ring-green-500" placeholder="0,00 €">
                    </div>
                    <div class="mb-4">
                        <label for="revenue-description" class="block text-sm font-medium text-slate-300 mb-2">Descrição</label>
                        <input type="text" id="revenue-description" name="description" class="w-full bg-slate-900 border border-slate-700 rounded-lg p-2 text-white focus:outline-none focus:ring-2 focus:ring-green-500" placeholder="Ex: Venda de bilhetes">
                    </div>
                    <div class="mb-6">
                        <label for="revenue-date" class="block text-sm font-medium text-slate-300 mb-2">Data</label>
                        <input type="date" id="revenue-date" name="date" class="w-full bg-slate-900 border border-slate-700 rounded-lg p-2 text-white focus:outline-none focus:ring-2 focus:ring-green-500">
                    </div>
                    <button type="submit" class="w-full bg-green-600 hover:bg-green-700 text-white font-bold py-2 px-4 rounded-lg transition-colors">
                        Criar
                    </button>
                </form>
            </div>
        </div>

        <!-- Modal Add Despesas -->
        <div id="expense-modal" class="fixed inset-0 bg-black bg-opacity-50 hidden items-center justify-center z-50">
            <div class="bg-slate-800 rounded-lg shadow-xl p-8 w-full max-w-md border border-slate-700">
                <div class="flex justify-between items-center mb-6">
                    <h2 class="text-2xl font-bold text-red-400">Adicionar Despesa</h2>
                    <button id="close-expense-modal" class="text-slate-400 hover:text-white">
                        <i data-feather="x"></i>
                    </button>
                </div>
                <form>
                    <div class="mb-4">
                        <label for="expense-amount" class="block text-sm font-medium text-slate-300 mb-2">Valor</label>
                        <input type="number" step="0.01" id="expense-amount" name="amount" class="w-full bg-slate-900 border border-slate-700 rounded-lg p-2 text-white focus:outline-none focus:ring-2 focus:ring-red-500" placeholder="0,00 €">
                    </div>
                    <div class="mb-4">
                        <label for="expense-description" class="block text-sm font-medium text-slate-300 mb-2">Descrição</label>
                        <input type="text" id="expense-description" name="description" class="w-full bg-slate-900 border border-slate-700 rounded-lg p-2 text-white focus:outline-none focus:ring-2 focus:ring-red-500" placeholder="Ex: Compra de material">
                    </div>
                    <div class="mb-6">
                        <label for="expense-date" class="block text-sm font-medium text-slate-300 mb-2">Data</label>
                        <input type="date" id="expense-date" name="date" class="w-full bg-slate-900 border border-slate-700 rounded-lg p-2 text-white focus:outline-none focus:ring-2 focus:ring-red-500">
                    </div>
                    <button type="submit" class="w-full bg-red-600 hover:bg-red-700 text-white font-bold py-2 px-4 rounded-lg transition-colors">
                        Criar
                    </button>
                </form>
            </div>
        </div>

        <!-- Modal Add Dinheiro -->
