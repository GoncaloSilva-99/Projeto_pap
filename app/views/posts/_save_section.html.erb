<%= turbo_frame_tag "save_section_#{post.id}", style: "display: contents;" do %>
            <% if post.saved_by?(current_user) %>
                <%= button_to post_post_saves_path(post),
                    method: :delete,
                    form: { class: "inline" },
                    class: "save-post-btn block px-4 py-2 text-sm text-gray-200 hover:bg-gray-600 rounded-t-md transition-colors hover:text-red-400 clickable",
                    data: { turbo_frame: "save_section_#{post.id}" } do %>
                    <i data-feather="bookmark" class="w-5 h-5 fill-current"></i>
                    <span> Retirar publicação dos guardados </span>
                <% end %>
            <% else %>
                <%= button_to post_post_saves_path(post),
                    method: :post,
                    form: { class: "inline" },
                    class: "save-post-btn block px-4 py-2 text-sm text-gray-200 hover:bg-gray-600 rounded-t-md transition-colors hover:text-green-400 clickable",
                    data: { turbo_frame: "save_section_#{post.id}" } do %>
                    <i data-feather="bookmark" class="w-5 h-5"></i>
                    <span> Guardar publicação </span>
                <% end %>
            <% end %>
    <script>
        feather.replace();
    </script>

<% end %>