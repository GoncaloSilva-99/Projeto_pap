<% @post_likes = @like.post_likes %>

<% if @post_likes.present? %>
    <% @post_lies.each do |like| %>
        
        <% 
            liker_profile = nil
            if like.user.club?
                liker_profile = like.user.club_profile
            elsif like.user.player?
                liker_profile = like.user.player_profile
            elsif like.user.board?
                liker_profile = like.user.board_profile
            elsif like.user.coach?
                liker_profile = like.user.coach_profile
            elsif like.user.admin?
                liker_profile = like.user.admin_profile
            elsif like.user.user?
                liker_profile = like.user.user_profile
            end
        %>

            <div id="followers-modal" class="fixed inset-0 z-[60] hidden flex justify-center items-center py-12" aria-labelledby="modal-title" role="dialog" aria-modal="true">
                <div class="fixed inset-0 bg-black bg-opacity-75 transition-opacity backdrop-blur-sm"></div>
                <div class="relative bg-gray-800 rounded-xl shadow-2xl w-11/12 md:w-1/3 h-full flex flex-col border border-gray-700 transform transition-all overflow-hidden">

                    <div class="relative flex items-center justify-center p-4 border-b border-gray-700 bg-gray-800 z-10">
                        <h3 class="text-lg font-bold text-white">Likes</h3>
                        <button data-modal-hide="modal-post-likes#<%@post%>" class="absolute right-4 text-gray-400 hover:text-white p-1 rounded-full hover:bg-gray-700 transition">
                            <i data-feather="x" class="w-5 h-5"></i>
                        </button>
                    </div>
                    <div class="flex-1 overflow-y-auto p-4 space-y-4 thin-scrollbar">
                        <div class="flex items-center justify-between hover:bg-gray-700 p-2 rounded-lg transition">
                            <div class="flex items-center gap-3">
                                <div class="w-10 h-10 rounded-full bg-gray-600 overflow-hidden">
                                    <% if liker_profile && liker_profile.profile_picture.attached? %>
                                        <%= image_tag url_for(liker_profile.profile_picture), class: "w-full h-full object-cover" %>
                                    <% else %>
                                        <%= image_tag "default_pp.jpg", class: "w-full h-full object-cover" %>
                                    <% end %>
                                </div>

                                <% if like.user.club? %>
                                    <%= link_to like.user.club_profile.name, club_profile_path(like.user.club_profile), 
                                        data: { turbo_frame: "_top" }, class: "hover:underline" %>
                                <% elsif like.user.player? %>
                                    <%= link_to like.user.player_profile.name, player_profile_path(like.user.player_profile), 
                                        data: { turbo_frame: "_top" }, class: "hover:underline" %>
                                <% elsif like.user.coach? %>
                                    <%= link_to like.user.coach_profile.name, coach_profile_path(like.user.coach_profile), 
                                        data: { turbo_frame: "_top" }, class: "hover:underline" %>
                                <% elsif like.user.board? %>
                                    <%= link_to like.user.board_profile.name, board_profile_path(like.user.board_profile), 
                                        data: { turbo_frame: "_top" }, class: "hover:underline" %>
                                <% elsif like.user.user? %>
                                    <%= link_to like.user.user_profile.name, user_profile_path(like.user.user_profile), 
                                        data: { turbo_frame: "_top" }, class: "hover:underline" %>
                                <% end %>
                            </div>

                            <button class="px-3 py-1 bg-gray-600 hover:bg-gray-500 text-white text-sm font-medium rounded-md transition flex items-center gap-1">
                                <i data-feather="user-check" class="w-4 h-4"></i>
                                <span>Seguir</span>
                            </button>
                        </div>

                        
                    </div>
                </div>
            </div>
<% else %>
    <div class="bg-gray-800 rounded-xl p-12 text-center">
        <i data-feather="heart" class="w-16 h-16 text-gray-600 mx-auto mb-4"></i>
        <h3 class="text-xl font-bold text-gray-400 mb-2">Este post ainda não tem nenhum like!</h3>
    </div>
<% end %>

<script>
    feather.replace();
</script>