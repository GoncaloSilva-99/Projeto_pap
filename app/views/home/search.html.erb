                        </svg>              
                    </button>
                    <!-- Dropdown menu -->
                    <div class="rounded-lg hidden overflow-hidden z-50 my-4 max-w-sm text-base list-none bg-white rounded divide-y divide-gray-100 shadow-lg dark:bg-gray-700 dark:divide-gray-600" id="apps-dropdown">
