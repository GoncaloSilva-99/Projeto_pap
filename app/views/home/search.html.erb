  <main class="container mx-auto px-4 pt-24 pb-10">
    <% selected_category = params[:category].presence || 'perfis' %>
    <% selected_label = selected_category == 'publicacoes' ? 'Publicações' : 'Perfis' %>

    <div class="flex flex-col md:flex-row justify-between items-center gap-3 mb-4">
      <div class="flex items-center gap-2">
        <span class="text-sm text-gray-300 hidden md:inline">Filtrar por:</span>
        <div class="relative">
          <button id="search-category-button" class="inline-flex items-center justify-between gap-2 rounded-xl border border-gray-600 bg-gray-800 px-3 py-2 text-sm font-medium text-white hover:border-yellow-500" type="button">
            <i data-feather="filter" class="w-4 h-4"></i>
            <span class="font-semibold"><%= selected_label %></span>
            <i data-feather="chevron-down" class="w-3 h-3"></i>
          </button>
          <div id="search-category-menu" class="hidden absolute left-0 mt-2 w-44 rounded-xl border border-gray-700 bg-gray-800 shadow-xl z-20">
            <%= link_to "Perfis", "#{request.path}?#{request.query_parameters.merge(category: 'perfis').to_query}", class: "block px-4 py-2 text-sm text-white hover:bg-gray-700" %>
            <%= link_to "Publicações", "#{request.path}?#{request.query_parameters.merge(category: 'publicacoes').to_query}", class: "block px-4 py-2 text-sm text-white hover:bg-gray-700" %>
          </div>
        </div>
      </div>

      <div class="flex-1 md:flex-none w-full md:w-auto">
        <form action="<%= home_search_path %>" method="get" class="flex justify-end">
          <input type="hidden" name="category" value="<%= selected_category %>">
          <input name="query" id="query-search" type="text" value="<%= params[:query] %>" placeholder="Pesquisar..." class="w-full md:w-96 bg-gray-700 border border-gray-600 rounded-full px-3 py-2 text-sm text-white placeholder-gray-300 focus:outline-none focus:ring-1 focus:ring-blue-500 focus:border-blue-500 transition duration-200" />
          <button type="submit" class="ml-2 bg-blue-600 hover:bg-blue-700 text-white hover:bg-blue-500 hover:text-gray-900 px-3 py-2 rounded-full text-gray-900 font-semibold transition duration-200">
            <i data-feather="search" class="w-5 h-5"></i>
          </button>
        </form>
      </div>
    </div>

    <div class="mb-4">
      <h1 class="text-2xl md:text-3xl font-bold text-white mb-8 mt-4">Resultados para "<%= params[:query].to_s.truncate(80) %>"</h1>
    </div>

    <% if selected_category == 'publicacoes' %>
      <div class="space-y-4">
        <% posts = @post_results || @posts || [] %>
        <% if posts.any? %>
          <% posts.each do |post| %>
            <% post_profile = if post.user.club? then post.user.club_profile elsif post.user.player? then post.user.player_profile elsif post.user.coach? then post.user.coach_profile elsif post.user.board? then post.user.board_profile elsif post.user.admin? then post.user.admin_profile elsif post.user.user? then post.user.user_profile end %>
            <div class="bg-gray-800 border border-gray-700 rounded-2xl p-4 hover:border-yellow-400 hover:shadow-xl transition-all duration-200">
              <div class="flex items-start justify-between gap-3">
                <div class="flex items-start gap-3">
                  <div class="w-10 h-10 rounded-full bg-gray-700 overflow-hidden">
                    <% if post_profile&.profile_picture&.attached? %>
                      <%= image_tag url_for(post_profile.profile_picture), class: "w-full h-full object-cover" %>
                    <% else %>
                      <%= image_tag "default_pp.jpg", class: "w-full h-full object-cover" %>
                    <% end %>
                  </div>
                  <div>
                    <p class="font-semibold text-white"><%= post_profile&.name || post.user.email %></p>
                    <p class="text-xs text-gray-400"><%= time_ago_in_words(post.created_at) %> atrás</p>
                  </div>
                </div>
                <span class="text-xs text-gray-300 bg-gray-700 px-2 py-1 rounded-full"><%= post.respond_to?(:private?) && post.private? ? 'Privado' : 'Público' %></span>
              </div>
              <div class="mt-3 text-gray-200"><%= simple_format(post.caption || post.text || 'Sem descrição') %></div>
              <% if post.respond_to?(:photos) && post.photos.attached? %>
                <div class="mt-3 grid grid-cols-2 gap-2">
                  <% post.photos.each do |photo| %>
                    <%= image_tag url_for(photo), class: "w-full h-28 object-cover rounded-lg" %>
                  <% end %>
                </div>
              <% end %>
              <div class="mt-3 flex items-center gap-3 text-gray-300 text-sm">
                <span><i data-feather="heart" class="inline w-4 h-4"></i> <%= post.likes_count || 0 %></span>
                <span><i data-feather="message-circle" class="inline w-4 h-4"></i> <%= post.comments_count || 0 %></span>
              </div>
            </div>
          <% end %>
        <% else %>
          <div class="bg-gray-800 border border-gray-700 rounded-2xl p-6 text-center text-gray-300">
            Nenhuma publicação encontrada para esta pesquisa.
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4">
        <% profiles = @profile_results || @profiles || [] %>
        <% if profiles.any? %>
          <% profiles.each do |profile| %>
            <% profile_name = profile.try(:name) || profile.try(:full_name) || profile.try(:nickname) || "Perfil" %>
            <% profile_role = profile.try(:coach_type) || profile.try(:sport) || profile.try(:role) || "Perfil" %>
            <% profile_url = if profile.respond_to?(:user_profile) && profile.user_profile.present? then user_profile_path(profile.user_profile)
                              elsif profile.is_a?(ClubProfile) then club_profile_path(profile)
                              elsif profile.is_a?(CoachProfile) then coach_profile_path(profile)
                              elsif profile.is_a?(PlayerProfile) then player_profile_path(profile)
                              elsif profile.is_a?(BoardProfile) then board_profile_path(profile)
                              else "#" end %>
            <%= link_to profile_url, class: "group block bg-gray-800 border border-gray-700 rounded-2xl overflow-hidden hover:border-yellow-500 hover:shadow-xl transition-all duration-200" do %>
              <div class="relative h-24 bg-gradient-to-r from-primary/20 to-secondary/20 group-hover:opacity-95 transition duration-200">
                <% if profile.respond_to?(:banner_picture) && profile.banner_picture.attached? %>
                  <%= image_tag url_for(profile.banner_picture), class: "w-full h-full object-cover" %>
                <% else %>
                  <div class="w-full h-full bg-gradient-to-r from-gray-700 via-gray-800 to-gray-700"></div>
                <% end %>
                <div class="absolute -bottom-8 left-4 w-16 h-16 rounded-full border-4 border-gray-900 bg-gray-700 overflow-hidden">
                  <% if profile.respond_to?(:profile_picture) && profile.profile_picture.attached? %>
                    <%= image_tag url_for(profile.profile_picture), class: "w-full h-full object-cover" %>
                  <% else %>
                    <%= image_tag "default_pp.jpg", class: "w-full h-full object-cover" %>
                  <% end %>
                </div>
              </div>
              <div class="p-4 pt-10">
                <p class="text-lg font-semibold text-white"><%= profile_name %></p>
                <p class="text-gray-400 text-sm"><%= profile_role %></p>
                <% if profile.respond_to?(:city) && profile.city.present? %>
                  <p class="text-gray-300 text-sm mt-1"><%= profile.city %></p>
                <% end %>
              </div>
            <% end %>
          <% end %>
        <% else %>
          <div class="col-span-1 md:col-span-2 xl:col-span-3 bg-gray-800 border border-gray-700 rounded-2xl p-6 text-center text-gray-300">
            Nenhum perfil encontrado para esta pesquisa.
          </div>
        <% end %>
      </div>
    <% end %>
  </main>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const button = document.getElementById('search-category-button');
      const menu = document.getElementById('search-category-menu');
      if (button && menu) {
        button.addEventListener('click', () => {
          menu.classList.toggle('hidden');
        });
        document.addEventListener('click', (e) => {
          if (!button.contains(e.target) && !menu.contains(e.target)) {
            menu.classList.add('hidden');
          }
        });
      }
      if (window.feather) {
        feather.replace();
      }
    });
  </script>
</body>
