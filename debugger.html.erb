<body class="min-h-screen flex text-white bg-gray-900">
<!---------------------------------------------------- NOME E LOGO DO CLUBE ---------------------------------------------------->
    <div class="w-64 bg-slate-800 shadow-xl min-h-screen flex flex-col border-r border-slate-700">
    <!-- Logo e nome do clube -->
        <div class="p-6 border-b border-slate-700">
            <div class="flex items-center justify-center mb-3">
                
                <% if (current_user.club? and current_user.club_profile.profile_picture.attached?) %>
                    <%= image_tag url_for(current_user.club_profile.profile_picture), class: "w-20 h-20 rounded-full border-1" %>
                <% elsif (current_user.board? && current_user.board_profile.club_profile.profile_picture.attached?) %>
                    <%= image_tag url_for(current_user.board_profile.club_profile.profile_picture), class: "w-20 h-20 rounded-full border-1" %>
                <% else %>
                    <%= image_tag "default_pp.jpg", class: "w-20 h-20 rounded-full border-1" %>
                <% end %>

                
            </div>
            <h1 class="text-lg font-bold text-center text-white">
                <% if current_user.club? %>
                    <%= current_user.club_profile.name %>
                <% elsif current_user.board? %>
                    <%= current_user.board_profile.club_profile.name %>
                <% end %>
            </h1>
        </div>
<!---------------------------------------------------- OPÇÕES DO SIDEBAR ---------------------------------------------------->
        <nav class="flex-1 p-4 space-y-2">
            
            <%= link_to club_dashboard_path do %>
            <div class="sidebar-item flex items-center px-4 py-3 text-slate-300 hover:bg-slate-700 hover:text-blue-400 rounded-xl border-l-4 border-transparent hover:border-blue-500 transition-all duration-300">
                <i data-feather="home" class="sidebar-icon text-blue-400 w-5 h-5 mr-3"></i>
                <span class="font-medium">Dashboard</span>
            </div>
            <% end %>

            <%= link_to club_teams_dashboard_path do %>
            <div class="sidebar-item flex items-center px-4 py-3 text-slate-300 hover:bg-slate-700 hover:text-green-400 rounded-xl border-l-4 border-transparent hover:border-green-500 transition-all duration-300">
                <i data-feather="users" class="sidebar-icon text-green-400 w-5 h-5 mr-3"></i>
                <span class="font-medium">Equipas</span>
            </div>
            <% end %>


            <%= link_to club_finances_dashboard_path do %>
            <div  class="sidebar-item flex items-center px-4 py-3 bg-slate-700 text-yellow-400 rounded-xl border-l-4 border-yellow-500 transition-all duration-300">
                <i data-feather="dollar-sign" class="sidebar-icon text-yellow-400 w-5 h-5 mr-3"></i>
                <span class="font-medium">Finanças</span>
            </div>
            <% end %>

            <%= link_to root_path do %>
            <div class="sidebar-item flex items-center px-4 py-3 text-slate-300 hover:bg-slate-700 hover:text-red-400 rounded-xl border-l-4 border-transparent hover:border-red-500 transition-all duration-300">
                <i data-feather="heart" class="sidebar-icon text-red-400 w-5 h-5 mr-3"></i>
                <span class="font-medium">Adeptos</span>
            </div>
            <% end %>


            <%= link_to club_infrastructures_dashboard_path do %>
            <div class="sidebar-item flex items-center px-4 py-3 text-slate-300 hover:bg-slate-700 hover:text-orange-400 rounded-xl border-l-4 border-transparent hover:border-orange-500 transition-all duration-300">
                <i data-feather="map-pin" class="sidebar-icon text-orange-400 w-5 h-5 mr-3"></i>
                <span class="font-medium">Infraestruturas</span>
            </div>
            <% end %>

            <%= link_to club_equipment_dashboard_path do %>
            <div class="sidebar-item flex items-center px-4 py-3 text-slate-300 hover:bg-slate-700 hover:text-rose-400 rounded-xl border-l-4 border-transparent hover:border-rose-300 transition-all duration-300">
                <i data-feather="clipboard" class="sidebar-icon text-rose-400 w-5 h-5 mr-3"></i>
                <span class="font-medium">Material</span>
            </div>
            <% end %>

            <%= link_to club_board_dashboard_path do %>
            <div class="sidebar-item flex items-center px-4 py-3 text-slate-300 hover:bg-slate-700 hover:text-rose-900 rounded-xl border-l-4 border-transparent hover:border-rose-950 transition-all duration-300">
                <i data-feather="settings" class="sidebar-icon text-rose-900 w-5 h-5 mr-3"></i>
                <span class="font-medium">Membros da Direção</span>
            </div>
            <% end %>

            <%= link_to root_path do %>
            <div class="sidebar-item flex items-center px-4 py-3 text-slate-300 hover:bg-slate-700 hover:text-gray-400 rounded-xl border-l-4 border-transparent hover:border-gray-400 transition-all duration-300">
                <i data-feather="arrow-left" class="sidebar-icon text-gray-400 w-5 h-5 mr-3"></i>
                <span class="font-medium">Página Inicial</span>
            </div>
            <% end %>
        </nav>


        <div class="p-4 border-t border-slate-700">
            <div class="flex items-center space-x-3">
                <% if (current_user.club? and current_user.club_profile.profile_picture.attached?) %>
                    <%= image_tag url_for(current_user.club_profile.profile_picture), class: "w-10 h-10 rounded-full border-2 border-slate-600" %>
                <% elsif (current_user.board? and current_user.board_profile.profile_picture.attached?) %>
                    <%= image_tag url_for(current_user.board_profile.profile_picture), class: "w-10 h-10 rounded-full border-2 border-slate-600" %>
                <% else %>
                    <%= image_tag "default_pp.jpg", class: "w-10 h-10 rounded-full border-2 border-slate-600" %>
                <% end %>
                <div class="flex-1">
                    <% if current_user.club? %>
                        <p class="text-sm font-medium text-white"> <%= current_user.club_profile.name %> </p>
                    <% elsif current_user.board? %>
                        <p class="text-sm font-medium text-white"> <%= current_user.board_profile.name %> </p>
                    <% end %>
                </div>
                <i data-feather="log-out" class="text-slate-400 hover:text-red-400 cursor-pointer transition-colors"></i>
            </div>
        </div>
</div>
<!---------------------------------------------------- MAIN CONTENT ---------------------------------------------------->
    <div class="flex-1 p-8 overflow-auto">
        <div class="flex justify-center items-center mb-8">
            <button class="p-2 rounded-full hover:bg-slate-700 transition-colors">
                <i data-feather="chevron-left" class="w-8 h-8 text-slate-400"></i>
            </button>
            <h1 class="text-4xl font-bold mx-8 text-white tracking-wider">Março 2026</h1>
            <button class="p-2 rounded-full hover:bg-slate-700 transition-colors">
                <i data-feather="chevron-right" class="w-8 h-8 text-slate-400"></i>
            </button>
        </div>

        <hr class="border-slate-700 my-8">

        <%
        current_club = current_user.club? ? current_user.club_profile : current_user.board_profile.club_profile
        current_balance = current_club.club_balance
        monthly_incomes = current_club.club_incomes.where(date: Date.current.all_month).sum(:value)
        monthly_expenses = current_club.club_expenses.where(date: Date.current.all_month).sum(:value)
        %>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
            <div class="bg-slate-800 rounded-xl shadow-lg p-6 border border-slate-700 flex flex-col">
                <div class="flex items-center justify-between mb-4">
                    <h3 class="text-lg font-semibold text-white">Carteira</h3>
                    <i data-feather="briefcase" class="text-blue-400"></i>
                </div>
                
                <% if current_balance.present? %>
                <div id="wallet-balance-view" class="flex-grow flex flex-col justify-between">
                    <div class="flex-grow">
                        <div class="flex items-center mb-1">
                            <p id="wallet-balance-amount" class="text-3xl font-bold text-white">
                                <%= number_to_currency(current_balance.value, unit: "€", separator: ",", delimiter: ".", format: "%n %u") %>
                            </p>
                            <button class="add-money-trigger ml-3 p-1.5 bg-slate-700 hover:bg-blue-600 rounded-lg text-white transition-colors" title="Adicionar Dinheiro">
                                <i data-feather="edit-3" class="w-5 h-5"></i>
                            </button>
                        </div>
                        <p class="text-sm text-slate-400">Valor em caixa</p>
                    </div>
                </div>
                <% else %>
                <div id="wallet-empty-view" class="flex-grow flex items-center justify-center">
                    <button class="add-money-trigger w-full bg-slate-700 hover:bg-slate-600 text-slate-300 px-4 py-3 rounded-lg font-medium transition-colors opacity-80 hover:opacity-100">
                        Adicionar Dinheiro à Conta
                    </button>
                </div>
                <% end %>
            </div>

            <!-- Receitas -->
            <div class="bg-slate-800 rounded-xl shadow-lg p-6 border border-slate-700">
                <div class="flex items-center justify-between mb-4">
                    <h3 class="text-lg font-semibold text-white">Receitas do Mês</h3>
                    <i data-feather="arrow-up-circle" class="text-green-400"></i>
                </div>
                <p class="text-3xl font-bold text-green-400">
                + <%= number_to_currency(monthly_incomes, unit: "€", separator: ",", delimiter: ".", format: "%n %u") %>
                </p>
                <p class="text-sm text-slate-400">Total de entradas em <%= l(Date.current, format: "%B %Y") %></p>
            </div>

            <!-- Despesas -->
            <div class="bg-slate-800 rounded-xl shadow-lg p-6 border border-slate-700">
                <div class="flex items-center justify-between mb-4">
                    <h3 class="text-lg font-semibold text-white">Despesas do Mês</h3>
                    <i data-feather="arrow-down-circle" class="text-red-400"></i>
                </div>
                <p class="text-3xl font-bold text-red-400">
                - <%= number_to_currency(monthly_expenses, unit: "€", separator: ",", delimiter: ".", format: "%n %u") %>
                </p>
                <p class="text-sm text-slate-400">Total de saídas em <%= l(Date.current, format: "%B %Y") %></p>
            </div>
        </div>

        <!-- Linha de Separador -->
        <hr class="border-slate-700 my-8">

        <h3 class="text-3xl font-semibold text-blue-300 mb-4">Receitas/Despesas</h3>

        <!-- Searchbar e Botões de Add-->
        <div class="flex justify-between items-center mb-8">
            <!-- Searchbar -->
            <div class="relative w-1/3">
                <i id="search-icon" data-feather="search" class="absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 cursor-pointer hover:text-white transition-colors"></i>
                <input id="search-input" type="text" placeholder="Pesquisar transações..." class="bg-slate-800 border border-slate-700 rounded-lg py-2 pl-10 pr-4 text-white w-full focus:outline-none focus:ring-2 focus:ring-blue-500">
            </div>

            <!-- Botões de Add Receitas/Despesas -->
            <div class="flex space-x-4">
                <button id="add-revenue-button" title="Adicionar Receita" class="p-2 bg-green-600 hover:bg-green-700 rounded-lg text-white transition-colors">
                    <i data-feather="plus-circle"></i>
                </button>
                <button id="add-expense-button" title="Adicionar Despesa" class="p-2 bg-red-600 hover:bg-red-700 rounded-lg text-white transition-colors">
                    <i data-feather="plus-circle"></i>
                </button>
            </div>
        </div>

        <!-- Lista Receitas/Despesas -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-x-8">
            <!-- Coluna de Receitas -->
            <div class="md:pr-4">
                <h3 class="text-2xl font-semibold text-green-400 mb-4">Receitas</h3>
                <div class="pr-2 max-h-72 overflow-y-auto no-scrollbar" id="revenue-scroll-container">
                    <div class="space-y-4" id="revenue-list">
                        <% current_club.club_incomes.order(date: :desc).each do |income| %>
                        <div class="flex justify-between items-center bg-slate-800 p-3 rounded-lg border border-slate-700">
                            <div>
                                <p class="font-medium text-white"><%= income.description %></p>
                                <p class="text-sm text-slate-400"><%= l(income.date, format: :long) %></p>
                            </div>
                            <span class="font-bold text-green-400">
                                + <%= number_to_currency(income.value, unit: "€", separator: ",", delimiter: ".", format: "%n %u") %>
                            </span>
                        </div>
                        <% end %>
                    </div>
                </div>
                <div class="mt-4 text-center">
                    <button id="load-more-revenues" class="text-blue-400 hover:text-blue-300 text-sm font-medium hidden">Carregar mais</button>
                    <p id="end-revenues-msg" class="text-slate-500 text-sm hidden">------------------------- FIM -------------------------</p>
                </div>
            </div>

            <!-- Coluna de Despesas -->
            <div class="border-t border-slate-700 md:border-t-0 md:border-l md:border-slate-700 md:pl-8 pt-8 md:pt-0 mt-8 md:mt-0">
                <h3 class="text-2xl font-semibold text-red-400 mb-4">Despesas</h3>
                <div class="pr-2 max-h-72 overflow-y-auto no-scrollbar" id="expense-scroll-container">
                    <div class="space-y-4" id="expense-list">
                        <% current_club.club_expenses.order(date: :desc).each do |expense| %>
                        <div class="flex justify-between items-center bg-slate-800 p-3 rounded-lg border border-slate-700">
                            <div>
                                <p class="font-medium text-white"><%= expense.description %></p>
                                <p class="text-sm text-slate-400"><%= l(expense.date, format: :long) %></p>
                            </div>
                            <span class="font-bold text-red-400">
                                - <%= number_to_currency(expense.value, unit: "€", separator: ",", delimiter: ".", format: "%n %u") %>
                            </span>
                        </div>
                        <% end %>
                    </div>
                </div>
                <div class="mt-4 text-center">
                    <button id="load-more-expenses" class="text-blue-400 hover:text-blue-300 text-sm font-medium hidden">Carregar mais</button>
                    <p id="end-expenses-msg" class="text-slate-500 text-sm hidden">------------------------- FIM -------------------------</p>
                </div>
            </div>
        </div>

        <!-- Modal Add Receitas -->
        <div id="revenue-modal" class="fixed inset-0 bg-black bg-opacity-50 hidden items-center justify-center z-50">
            <div class="bg-slate-800 rounded-lg shadow-xl p-8 w-full max-w-md border border-slate-700">
                <div class="flex justify-between items-center mb-6">
                    <h2 class="text-2xl font-bold text-green-400">Adicionar Receita</h2>
                    <button id="close-revenue-modal" class="text-slate-400 hover:text-white">
                        <i data-feather="x"></i>
                    </button>
                </div>
                <%=
                # form_with gera o form com o método POST para /club_incomes
                # local: false envia via AJAX sem recarregar a página
                # data: { turbo: false } garante compatibilidade se usares Turbo/Hotwire
                %>
                <%= form_with url: club_incomes_path, local: false, data: { turbo: false } do |f| %>
                    <div class="mb-4">
                        <label class="block text-sm font-medium text-slate-300 mb-2">Valor</label>
                        <%=
                        # name: "club_income[value]" é o formato que o Rails espera
                        # para fazer params.require(:club_income).permit(:value)
                        %>
                        <%= f.number_field :value, step: 0.01, class: "w-full bg-slate-900 border border-slate-700 rounded-lg p-2 text-white focus:outline-none focus:ring-2 focus:ring-green-500", placeholder: "0,00 €" %>
                    </div>
                    <div class="mb-4">
                        <label class="block text-sm font-medium text-slate-300 mb-2">Descrição</label>
                        <%= f.text_field :description, class: "w-full bg-slate-900 border border-slate-700 rounded-lg p-2 text-white focus:outline-none focus:ring-2 focus:ring-green-500", placeholder: "Ex: Venda de bilhetes" %>
                    </div>
                    <div class="mb-6">
                        <label class="block text-sm font-medium text-slate-300 mb-2">Data</label>
                        <%= f.date_field :date, class: "w-full bg-slate-900 border border-slate-700 rounded-lg p-2 text-white focus:outline-none focus:ring-2 focus:ring-green-500" %>
                    </div>
                    <%= f.submit "Criar", class: "w-full bg-green-600 hover:bg-green-700 text-white font-bold py-2 px-4 rounded-lg transition-colors cursor-pointer" %>
                <% end %>
            </div>
        </div>

        <!-- Modal Add Despesas -->
        <div id="expense-modal" class="fixed inset-0 bg-black bg-opacity-50 hidden items-center justify-center z-50">
            <div class="bg-slate-800 rounded-lg shadow-xl p-8 w-full max-w-md border border-slate-700">
                <div class="flex justify-between items-center mb-6">
                    <h2 class="text-2xl font-bold text-red-400">Adicionar Despesa</h2>
                    <button id="close-expense-modal" class="text-slate-400 hover:text-white">
                        <i data-feather="x"></i>
                    </button>
                </div>
                <%= form_with url: club_expenses_path, local: false, data: { turbo: false } do |f| %>
                    <div class="mb-4">
                        <label class="block text-sm font-medium text-slate-300 mb-2">Valor</label>
                        <%= f.number_field :value, step: 0.01, class: "w-full bg-slate-900 border border-slate-700 rounded-lg p-2 text-white focus:outline-none focus:ring-2 focus:ring-red-500", placeholder: "0,00 €" %>
                    </div>
                    <div class="mb-4">
                        <label class="block text-sm font-medium text-slate-300 mb-2">Descrição</label>
                        <%= f.text_field :description, class: "w-full bg-slate-900 border border-slate-700 rounded-lg p-2 text-white focus:outline-none focus:ring-2 focus:ring-red-500", placeholder: "Ex: Compra de material" %>
                    </div>
                    <div class="mb-6">
                        <label class="block text-sm font-medium text-slate-300 mb-2">Data</label>
                        <%= f.date_field :date, class: "w-full bg-slate-900 border border-slate-700 rounded-lg p-2 text-white focus:outline-none focus:ring-2 focus:ring-red-500" %>
                    </div>
                    <%= f.submit "Criar", class: "w-full bg-red-600 hover:bg-red-700 text-white font-bold py-2 px-4 rounded-lg transition-colors cursor-pointer" %>
                <% end %>
            </div>
        </div>

        <!-- Modal Alterar Saldo -->
        <div id="add-money-modal" class="fixed inset-0 bg-black bg-opacity-50 hidden items-center justify-center z-50">
            <div class="bg-slate-800 rounded-lg shadow-xl p-8 w-full max-w-md border border-slate-700">
                <div class="flex justify-between items-center mb-6">
                    <h2 class="text-2xl font-bold text-blue-400">Alterar Saldo da Conta</h2>
                    <button id="close-add-money-modal" class="text-slate-400 hover:text-white">
                        <i data-feather="x"></i>
                    </button>
                </div>
                <%=
                # club_current_balance_path aponta para PATCH /club_current_balance
                # como é um "resource" singular (há só um por clube), não precisa de ID
                %>
                <%= form_with url: club_current_balance_path, method: :patch, local: false, data: { turbo: false }, id: "add-money-form" do |f| %>
                    <div class="mb-6">
                        <label class="block text-sm font-medium text-slate-300 mb-2">Quantia</label>
                        <%= f.number_field :value, step: 0.01, class: "w-full bg-slate-900 border border-slate-700 rounded-lg p-2 text-white focus:outline-none focus:ring-2 focus:ring-blue-500", placeholder: "0,00 €", required: true, id: "add-money-amount" %>
                    </div>
                    <%= f.submit "Alterar", class: "w-full bg-blue-600 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded-lg transition-colors cursor-pointer" %>
                <% end %>
            </div>
        </div>
    </div>
    
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            feather.replace();

            // --- MODAL LOGIC ---
            const openModal = (modal) => {
                if (!modal) return;
                modal.classList.remove('hidden');
                modal.classList.add('flex');
                feather.replace();
            };

            const closeModal = (modal) => {
                if (!modal) return;
                modal.classList.add('hidden');
                modal.classList.remove('flex');
            };

            const revenueModal = document.getElementById('revenue-modal');
            const addRevenueBtn = document.getElementById('add-revenue-button');
            const closeRevenueBtn = document.getElementById('close-revenue-modal');
            addRevenueBtn?.addEventListener('click', () => openModal(revenueModal));
            closeRevenueBtn?.addEventListener('click', () => closeModal(revenueModal));

            const expenseModal = document.getElementById('expense-modal');
            const addExpenseBtn = document.getElementById('add-expense-button');
            const closeExpenseBtn = document.getElementById('close-expense-modal');
            addExpenseBtn?.addEventListener('click', () => openModal(expenseModal));
            closeExpenseBtn?.addEventListener('click', () => closeModal(expenseModal));

            const addMoneyModal = document.getElementById('add-money-modal');
            const addMoneyTriggers = document.querySelectorAll('.add-money-trigger');
            const closeAddMoneyBtn = document.getElementById('close-add-money-modal');

            addMoneyTriggers.forEach(button => {
                button.addEventListener('click', () => openModal(addMoneyModal));
            });
            closeAddMoneyBtn?.addEventListener('click', () => closeModal(addMoneyModal));

            // Após submeter qualquer form via AJAX, recarrega a página para mostrar os novos dados
            // O Rails responde ao form_with local:false com um redirect, e o fetch/xhr trata disso
            document.querySelectorAll('form').forEach(form => {
                form.addEventListener('ajax:success', () => {
                    window.location.reload();
                });
                form.addEventListener('ajax:error', () => {
                    alert('Ocorreu um erro. Tente novamente.');
                });
            });

            window.addEventListener('click', (event) => {
                if (event.target === revenueModal) closeModal(revenueModal);
                if (event.target === expenseModal) closeModal(expenseModal);
                if (event.target === addMoneyModal) closeModal(addMoneyModal);
            });

            window.addEventListener('keydown', (event) => {
                if (event.key === 'Escape') {
                    if (revenueModal && !revenueModal.classList.contains('hidden')) closeModal(revenueModal);
                    if (expenseModal && !expenseModal.classList.contains('hidden')) closeModal(expenseModal);
                    if (addMoneyModal && !addMoneyModal.classList.contains('hidden')) closeModal(addMoneyModal);
                }
            });

            // --- LOAD MORE LOGIC ---
            const setupLoadMore = (listId, containerId, buttonId, endMessageId, itemsPerLoad) => {
                const list = document.getElementById(listId);
                const container = document.getElementById(containerId);
                const button = document.getElementById(buttonId);
                const endMessage = document.getElementById(endMessageId);
                if (!list || !container || !button || !endMessage) return;

                const items = Array.from(list.children);
                let visibleCount = itemsPerLoad;

                items.forEach((item, index) => {
                    if (index >= visibleCount) {
                        item.classList.add('hidden');
                    }
                });

                const checkScroll = () => {
                    const isAtBottom = container.scrollHeight - container.scrollTop - container.clientHeight <= 3;

                    if (visibleCount >= items.length) {
                        button.classList.add('hidden');
                        if (isAtBottom) {
                            endMessage.classList.remove('hidden');
                        } else {
                            endMessage.classList.add('hidden');
                        }
                        return;
                    }

                    endMessage.classList.add('hidden');
                    if (isAtBottom) {
                        button.classList.remove('hidden');
                    } else {
                        button.classList.add('hidden');
                    }
                };

                container.addEventListener('scroll', checkScroll);
                checkScroll();

                button.addEventListener('click', () => {
                    const nextVisibleCount = visibleCount + itemsPerLoad;
                    for (let i = visibleCount; i < nextVisibleCount && i < items.length; i++) {
                        items[i].classList.remove('hidden');
                    }
                    visibleCount = nextVisibleCount;
                    checkScroll();
                });
            };

            setupLoadMore('revenue-list', 'revenue-scroll-container', 'load-more-revenues', 'end-revenues-msg', 3);
            setupLoadMore('expense-list', 'expense-scroll-container', 'load-more-expenses', 'end-expenses-msg', 3);
        });
    </script>

</body>

<style>
    .sidebar-icon {
        transition: all 0.3s ease;
    }
    
    .sidebar-item:hover .sidebar-icon {
        transform: translateX(5px);
    }

